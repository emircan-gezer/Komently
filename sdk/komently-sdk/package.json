{
  "name": "komently-sdk",
  "version": "1.0.0",
  "description": "Komently Comment System SDK for integrating comments into external websites",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/komently.css",
    "./dist/styles/komently.css": "./dist/styles/komently.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean && node scripts/copy-css.js",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build:sdk": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "comments",
    "sdk",
    "komently"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": "^0.548.0"
  },
  "dependencies": {}
}